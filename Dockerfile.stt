# ---------------------------------------------------------------------------
# STT-only GPU image for GCP Compute Engine (T4)
# ---------------------------------------------------------------------------
FROM pytorch/pytorch:2.1.0-cuda12.1-cudnn8-runtime

ENV DEBIAN_FRONTEND=noninteractive

# ---------------------------------------------------------------------------
# System dependencies
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        libsndfile1 \
        libsndfile1-dev \
        wget \
        git \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Python dependencies
# ---------------------------------------------------------------------------
WORKDIR /app

COPY requirements-stt.txt .

RUN pip install --no-cache-dir -r requirements-stt.txt

# ---------------------------------------------------------------------------
# Application files
# ---------------------------------------------------------------------------
COPY stt_service.py .
COPY stt_main.py .

# ---------------------------------------------------------------------------
# Runtime configuration
# ---------------------------------------------------------------------------
# Hugging Face cache — keep downloaded models inside the container volume
ENV HF_HOME=/app/.cache/huggingface

RUN mkdir -p /app/.cache

EXPOSE 8000

# ---------------------------------------------------------------------------
# Health check
# ---------------------------------------------------------------------------
HEALTHCHECK --interval=30s --timeout=10s --start-period=180s --retries=3 \
    CMD wget -qO- http://localhost:8000/health || exit 1

# ---------------------------------------------------------------------------
# Entrypoint
# ---------------------------------------------------------------------------
CMD ["uvicorn", "stt_main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
